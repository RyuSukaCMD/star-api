# ==========================================
# StarNova API - Environment Configuration
# ==========================================
# Copy this file to .env and adjust values

# ---- DOMAIN CONFIGURATION ----
# Set your custom domains here
DOMAIN_API=https://api.starnova.my.id
DOMAIN_DASHBOARD=https://dash.starnova.my.id
DOMAIN_MAIN=https://starnova.my.id

# ---- SERVER ----
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
API_PREFIX=/api/v1

# ---- MONGODB ----
MONGODB_URI=mongodb://localhost:27017/starnova
MONGODB_URI_TEST=mongodb://localhost:27017/starnova_test

# ---- REDIS ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT ----
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ---- ENCRYPTION ----
AES_SECRET=your-aes-256-encryption-key-32-chars
AES_IV=your-16-char-iv-key

# ---- API KEYS ----
API_KEY_PREFIX=snv_
API_KEY_LENGTH=32
API_KEY_DEFAULT_DAILY_LIMIT=100
API_KEY_DEFAULT_MONTHLY_LIMIT=3000

# ---- RATE LIMIT ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_MESSAGE=Too many requests, please try again later.

# ---- CORS ----
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# ---- LOGGING ----
LOG_LEVEL=debug
LOG_DIR=logs

# ---- UPLOAD ----
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# ---- SWAGGER ----
SWAGGER_TITLE=StarNova API
SWAGGER_DESCRIPTION=High Performance REST API Platform
SWAGGER_VERSION=1.0.0
SWAGGER_SERVER=http://localhost:5000

# ---- CACHE ----
CACHE_TTL=300

# ---- PAYMENT ----
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
XENDIT_API_KEY=
XENDIT_IS_PRODUCTION=false

# ---- EMAIL ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@starnova.my.id

# ---- WEBHOOK ----
WEBHOOK_SECRET=your-webhook-secret-key

# ---- ADMIN ----
ADMIN_EMAIL=admin@starnova.my.id
ADMIN_USERNAME=starnova
ADMIN_PASSWORD=SuperSecurePassword123!

# ---- WHATSAPP BOT ----
WHATSAPP_BOT_TOKEN=your-whatsapp-bot-token
WHATSAPP_BOT_ENABLED=false
WHATSAPP_OWNER_NUMBER=

# ---- VERIFICATION ----
VERIFICATION_REQUIRED=false

# ---- MAINTENANCE ----
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System is under maintenance. Please try again later.
