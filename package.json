{
  "name": "starnova-api",
  "version": "1.0.0",
  "description": "StarNova API - High Performance REST API Platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "docker:build": "docker build -t starnova-api .",
    "docker:run": "docker run -p 5000:5000 starnova-api",
    "docker:compose": "docker-compose up -d",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx src/database/seed.ts",
    "generate:docs": "tsx src/docs/generator.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.1.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.22.4",
    "redis": "^4.6.13",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.3.1",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.11.0",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "dotenv": "^16.4.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-validator": "^7.0.1",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "uuid": "^9.0.1",
    "crypto-js": "^4.2.0",
    "ua-parser-js": "^1.0.37",
    "request-ip": "^3.3.0",
    "geoip-lite": "^1.4.10",
    "nodemailer": "^6.9.9",
    "ejs": "^3.1.9"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.16",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/morgan": "^1.9.9",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.7",
    "@types/crypto-js": "^4.2.2",
    "@types/ua-parser-js": "^0.7.39",
    "@types/request-ip": "^3.3.7",
    "@types/geoip-lite": "^1.1.4",
    "@types/nodemailer": "^6.4.14",
    "@types/ejs": "^3.1.5",
    "@types/node-fetch": "^2.6.11",
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "vitest": "^1.2.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "prettier": "^3.2.4",
    "husky": "^9.0.7",
    "lint-staged": "^15.2.2"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
